# Copia a `.env` y rellena los valores. No commitees `.env`.
# Ver también: docs/COMANDOS.md, docs/Installation.md

# MLX (inferencia local Mac)
MLX_MODEL_PATH=/path/to/your/mlx/model
# Gemma 4: usar Python 3.10+ (p. ej. Homebrew python3.11–3.13); con 3.9, PyPI solo llega a mlx 0.29.x y no hay mlx_lm.models.gemma4.
MLX_PYTHON=/path/to/mlx_env/bin/python
MLX_PORT=8080
MLX_MODEL_ID=/path/to/your/mlx/model
# LoRA fine-tuned (mlx_lm.server --adapter-path): carpeta con adapters.safetensors + adapter_config.json
# Tras `duckops train -c config/lora_config.yaml`, suele ser:
# MLX_ADAPTER_PATH=packages/agents/train/gemma4/adapters_lora_yaml
# Alias ``gemma4`` / ``gemma-4`` (ChatOpenAI / Telegram /model) → misma cadena que precarga el servidor MLX (ruta o repo HF).
# Opcional si ``MLX_MODEL_PATH`` ya apunta a una ruta/repo con ``gemma`` en el id (p. ej. gemma4-e4b); si no, definir explícito:
# MLX_GEMMA4_MODEL_PATH=/path/to/gemma4-mlx-or-hf-repo
# ChatOpenAI→MLX: con Gemma, parallel_tool_calls=false por defecto (mlx_lm gemma4 tool parser usa json estricto).
# DUCKCLAW_MLX_PARALLEL_TOOL_CALLS=1
# Visión (Telegram foto): mlx_lm en MLX_PORT es solo TEXTO; image_url → 404 en el mismo puerto.
# No se puede «dejar en el mismo puerto» salvo mlx-vlm in-process en el venv del gateway o DUCKCLAW_VLM_MLX_HTTP_ALLOW_DEFAULT_LOOPBACK=1 (sigue sin funcionar con mlx_lm puro).
# Opción A — visión en otro puerto (mlx-openai-server): PyPI exige Python **>=3.11 y <3.13**.
#   mlx_lm en MLX_PYTHON suele ser 3.13 → usa un venv aparte y MLX_VISION_PYTHON:
#   /opt/homebrew/bin/python3.12 -m venv ~/mlx_vision312 && ~/mlx_vision312/bin/pip install mlx-openai-server
#   MLX_VISION_PYTHON=/Users/you/mlx_vision312/bin/python
#   bash packages/agents/train/scripts/start_mlx_vision.sh
#   El .venv Duckclaw en 3.14 no sirve (outlines-core / Rust).
#   MLX_PORT=8080
#   MLX_VISION_PORT=8081
#   DUCKCLAW_VLM_MLX_BASE_URL=http://127.0.0.1:8081/v1
#   DUCKCLAW_VLM_MLX_MODEL=<id exacto de GET http://127.0.0.1:8081/v1/models>
# Opción B — solo variable de puerto (sin URL completa): VLM_MLX_PORT=8081 (debe ≠ MLX_PORT).
# Gemma multimodal in-process: instala mlx-vlm en el venv del Gateway y NO desactives local (comenta VLM_MLX_DISABLE_LOCAL).
# sin servidor en ese puerto → ConnectError. MLX-Inference (mlx_lm) = MLX_PORT, solo texto.
# VLM_MLX_PORT=8081 o DUCKCLAW_VLM_MLX_BASE_URL=http://127.0.0.1:8081/v1
# Forzar intento HTTP al puerto de texto (inútil salvo stack custom): DUCKCLAW_VLM_MLX_HTTP_ALLOW_DEFAULT_LOOPBACK=1
# VLM_MLX_BASE_URL=http://127.0.0.1:8080/v1
# Timeout HTTP (s) para POST /v1/chat/completions hacia MLX VLM HTTP; default en código 60 (tope 120).
# DUCKCLAW_VLM_MLX_HTTP_TIMEOUT=90
# VLM_MLX_DISABLE_LOCAL=1
# Cadena VLM por defecto: mlx_vlm local / MLX HTTP → Gemini (GEMINI_API_KEY / GOOGLE_API_KEY). OpenAI visión solo con:
# DUCKCLAW_VLM_ALLOW_OPENAI_VISION=1
# Gateway con LLM local MLX: arranca antes el servidor OpenAI-compatible en MLX_PORT (`start_mlx.sh` → `run_mlx_lm_server.py` → `mlx_lm server`; carga .env + --adapter-path):
#   pm2 start config/ecosystem.mlx.config.cjs
# o: bash packages/agents/train/scripts/start_mlx.sh
# (Si PM2 ejecuta solo `python -m mlx_lm server` sin --adapter-path, mlx_lm mostrará «Adapter: None» y no usarás el LoRA.) Luego:
# DUCKCLAW_LLM_PROVIDER=mlx
# DUCKCLAW_LLM_MODEL=<mismo valor que MLX_MODEL_ID>
# DUCKCLAW_LLM_BASE_URL=http://127.0.0.1:8080/v1
# (y opcionalmente LLM_PROVIDER / LLM_MODEL / LLM_BASE_URL con los mismos valores).

# Observability (LangSmith / LangChain)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=duckclaw
SEND_TO_LANGSMITH=false

# Database (rutas relativas a la raíz del repo o absolutas; se resuelven con DUCKCLAW_REPO_ROOT)
# Multiplex: DUCKCLAW_WAR_ROOM_ACL_DB_PATH (opcional), luego FINANZ / JOB_HUNTER / SIATA, luego DUCKDB_PATH.
# No uses DUCKCLAW_DB_PATH (eliminada); PM2 vuelca el mismo esquema desde config/api_gateways_pm2.json.
DUCKCLAW_JOB_HUNTER_DB_PATH=db/private/<vault_user_id>/jobhunterdb1.duckdb
DUCKCLAW_FINANZ_DB_PATH=db/private/<vault_user_id>/finanzdb1.duckdb
DUCKCLAW_SIATA_DB_PATH=db/private/<vault_user_id>/siatadb1.duckdb
# Bot Telegram Quant Trader (multiplex path /api/v1/telegram/quanttrader)
DUCKCLAW_QUANT_TRADER_DB_PATH=db/private/<vault_user_id>/quant_traderdb1.duckdb

# LLM provider and model
# Preferencia runtime: DUCKCLAW_LLM_* (gateway/PM2). Si solo usas LLM_* abajo, build_llm las copia a DUCKCLAW_* al arrancar.
# DUCKCLAW_LLM_PROVIDER=groq
# DUCKCLAW_LLM_MODEL=llama-3.3-70b-versatile
# DUCKCLAW_LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/
DEEPSEEK_API_KEY=
# Groq (API OpenAI-compatible; https://console.groq.com/)
GROQ_API_KEY=
# Límites Groq (tier ~12k TPM): recorte de historial/tool output antes del invoke (estimación chars/4).
# DUCKCLAW_GROQ_MAX_INPUT_TOKENS=5000
# DUCKCLAW_GROQ_TOOL_MESSAGE_MAX_CHARS=3500
# DUCKCLAW_GROQ_MAX_OUTPUT_TOKENS=4096

# Reintentos ante fallos transitorios de inferencia (p. ej. MLX reiniciando, connection refused).
# Aplica a agent_node del worker y a la síntesis NL de egress. No sustituye operar MLX/PM2 estable.
# DUCKCLAW_LLM_INVOKE_MAX_ATTEMPTS=3
# DUCKCLAW_LLM_INVOKE_RETRY_DELAY_SEC=0.4

# Manager (grafo): replan plan → worker ante fallos recuperables (ver specs/features/agent-manager-replan-resilience.md).
# DUCKCLAW_AGENT_MAX_PLAN_ATTEMPTS=3
# DUCKCLAW_AGENT_REPLAN_STRATEGY=hybrid

# Gemini (opcional)
GOOGLE_API_KEY=

# Open Router (opcional)
# OPENROUTER_API_KEY=

# IBKR portfolio (ej. API en VPS vía Tailscale)
IBKR_PORTFOLIO_API_URL=http://100.x.x.x:8002/api/portfolio/summary
IBKR_PORTFOLIO_API_KEY=
# OHLCV por HTTP (GET /api/market/ohlcv — ver specs/features/Capadonna Lake OHLC SSH + IBKR Live.md).
# Solo URL base, sin ?ticker=...  Si el VPS no expone aún esa ruta, déjalo vacío.
# IBKR_MARKET_DATA_URL=http://100.x.x.x:8002/api/market/ohlcv
# Quant Trader: velas solo IB Gateway (GET /api/market/ibkr/historical; sin lake). Usa el MISMO host:puerto
# que IBKR_PORTFOLIO_API_URL (VPS/Tailscale). No uses 127.0.0.1:8002 salvo que la API corra en esa máquina o haya túnel.
# IBKR_GATEWAY_OHLCV_URL=http://100.x.x.x:8002/api/market/ibkr/historical
IBKR_MARKET_DATA_API_KEY=

# Capadonna Lake (SSH al VPS; rutas en el comando son del servidor remoto)
CAPADONNA_SSH_HOST=100.x.x.x
CAPADONNA_SSH_USER=capadonna
CAPADONNA_REMOTE_OHLC_CMD="/home/user/projects/Capadonna-Driller/.venv/bin/python /home/user/projects/Capadonna-Driller/scripts/export_lake_ohlcv.py {ticker} {timeframe} {lookback_days}"
CAPADONNA_SSH_KEY_PATH=~/.ssh/id_ed25519
CAPADONNA_HISTORICAL_TIMEFRAMES=1d,1w,1M,moc
# Añadir 1d si el lake SSH está offline y quieres diario vía HTTP (IBKR_MARKET_DATA_URL).
IBKR_REALTIME_TIMEFRAMES=1m,5m,15m,30m,1h
CAPADONNA_SSH_TIMEOUT=120

# Paper + HITL (/execute_signal): ver docs/COMANDOS.md § Finanz / quant
# IBKR_ACCOUNT_MODE=paper
# IBKR_EXECUTE_ORDER_URL=https://...
# Opcional: cuánto tiempo vale el grant tras /execute_signal (swing: p. ej. 86400)
# DUCKCLAW_QUANT_HITL_GRANT_TTL_SEC=600

# Túnel único (p. ej. Tailscale) + varios bots por path — `python scripts/register_webhooks.py`
# DUCKCLAW_PUBLIC_URL=https://tu-nodo.ts.net
# Formato: bot_name:bot_token:/api/v1/telegram/<slug> separado por comas (sin JSON).
# Incluye quanttrader si usas ese bot (token BotFather + path fijo):
# DUCKCLAW_TELEGRAM_WEBHOOK_ROUTES=finanz:...:/api/v1/telegram/finanz,...,quanttrader:<TOKEN_QUANT>:/api/v1/telegram/quanttrader

# Telegram (un token por bot / gateway PM2)
TELEGRAM_JOB_HUNTER_TOKEN=
TELEGRAM_FINANZ_TOKEN=
TELEGRAM_BI_ANALYST_TOKEN=
TELEGRAM_LEILA_TOKEN=
TELEGRAM_SIATA_TOKEN=
# Debe coincidir con secret_token en setWebhook si usas verificación
TELEGRAM_WEBHOOK_SECRET=

# Proyecto / gateway
# Máx. caracteres del título del plan en DMs de heartbeat (no dejar vacío si defines la var).
CHAT_PARALLEL_INVOCATIONS=true
TELEGRAM_MCP_ENABLED=1
HEARTBEAT_PLAN_TITLE_INLINE_MAX=90
DOTENV_IMMUTABLE=1
# DUCKCLAW_GATEWAY_TENANT_ID=default
# DUCKCLAW_DEFAULT_WORKER_ID=finanz
# DUCKCLAW_PM2_PROCESS_NAME=Finanz-Gateway
# DUCKCLAW_SHARED_DB_PATH=

REDIS_URL=redis://localhost:6379/0
# DUCKCLAW_MULTI_VAULT_INITIAL_VAULT_ID=

# Tavily (búsqueda web en workers que lo declaren)
TAVILY_API_KEY=

# Reddit MCP (Finanz; opcional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=DuckClaw:v1.0 (by /u/your_reddit_user)
REDDIT_USERNAME=
REDDIT_PASSWORD=
